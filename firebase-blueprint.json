{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and financial data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "photoURL": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "string" },
        "country": { "type": "string" },
        "pin": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "balance": { "type": "number" },
        "currency": { "type": "string" },
        "card": {
          "type": "object",
          "properties": {
            "number": { "type": "string" },
            "expiry": { "type": "string" },
            "cvv": { "type": "string" },
            "holderName": { "type": "string" },
            "type": { "type": "string" }
          }
        },
        "notifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["transfer_received", "transfer_sent", "system"] },
              "amount": { "type": "number" },
              "senderId": { "type": "string" },
              "message": { "type": "string" },
              "timestamp": { "type": "number" },
              "read": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["id", "name", "role", "balance", "card"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
