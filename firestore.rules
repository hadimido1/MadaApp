rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow users to read their own profile, and allow lookup of other users by their UID/Email for transfers
      allow read: if request.auth != null;
      
      // Allow users to update their own profile and participate in transactions
      allow write: if request.auth != null;
    }
  }
}
