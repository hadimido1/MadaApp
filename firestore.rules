rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      // Allow any authenticated user to read and write profiles (crucial for transfers, setup, and profile updates)
      allow read, write: if request.auth != null;
    }

    match /config/{document} {
      // Allow any client to read or write the master admin config
      allow read, write: if true;
    }

    match /auth_sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
